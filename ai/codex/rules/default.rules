# Codex exec policy. Rules control commands requested outside the sandbox.

prefix_rule(
    pattern = [["tofu", "terraform"]],
    decision = "forbidden",
    justification = "Do not run Terraform/OpenTofu locally. The tailscale-infra repo plans on PR and applies on merge through GitHub Actions.",
    match = [
        "tofu plan",
        "tofu apply",
        "terraform init",
        "terraform plan",
    ],
)

prefix_rule(
    pattern = [["rg", "jq", "ast-grep", "ls", "pwd", "wc", "cat"]],
    decision = "allow",
    justification = "Read-only inspection tools are safe to run outside the sandbox.",
    match = [
        "rg codex",
        "jq . file.json",
        "ast-grep --pattern foo",
        "ls -la",
        "pwd",
        "wc -l README.md",
        "cat AGENTS.md",
    ],
)

prefix_rule(
    pattern = ["git", ["status", "diff", "log", "show"]],
    decision = "allow",
    justification = "Read-only git inspection commands do not mutate the worktree.",
    match = [
        "git status --short",
        "git diff --stat",
        "git log --oneline -5",
        "git show HEAD",
    ],
)

prefix_rule(
    pattern = ["git", "branch", "--show-current"],
    decision = "allow",
    justification = "Reading the current branch does not mutate the worktree.",
    match = [
        "git branch --show-current",
    ],
    not_match = [
        "git branch -D old-branch",
    ],
)

prefix_rule(
    pattern = ["git", ["pull", "push"]],
    decision = "forbidden",
    justification = "Do not pull or push git remotes from Codex.",
    match = [
        "git pull",
        "git pull --rebase",
        "git push",
    ],
    not_match = [
        "git status --short",
        "git log --oneline -5",
    ],
)

prefix_rule(
    pattern = ["bd", ["onboard", "prime", "ready", "show"]],
    decision = "allow",
    justification = "Read-only beads commands provide issue-tracking context.",
    match = [
        "bd onboard --json",
        "bd prime",
        "bd ready --json",
        "bd show bd-123 --json",
    ],
)

prefix_rule(
    pattern = ["bd", ["create", "update", "dep", "search"]],
    decision = "allow",
    justification = "Creating and updating beads issues is part of the local issue-tracking workflow.",
    match = [
        "bd create \"Follow-up task\" --type task --priority 2 --json",
        "bd update bd-123 --status in_progress --json",
        "bd update bd-123 --claim --json",
        "bd dep add XBOL-mgo.9 XBOL-mgo.2 --json",
        "bd search \"registration finished email\" --json"
    ],
    not_match = [
        "bd push",
        "bd sync",
        "bd dolt push",
    ],
)

prefix_rule(
    pattern = ["bd", "push"],
    decision = "forbidden",
    justification = "Do not push beads directly. Beads state must not be pushed or synced from Codex.",
    match = [
        "bd push",
    ],
    not_match = [
        "bd ready --json",
    ],
)

prefix_rule(
    pattern = ["bd", "sync"],
    decision = "forbidden",
    justification = "Do not sync beads from Codex because bd sync pushes beads state.",
    match = [
        "bd sync",
    ],
    not_match = [
        "bd ready --json",
    ],
)

prefix_rule(
    pattern = ["bd", "dolt", "push"],
    decision = "forbidden",
    justification = "Do not push the beads Dolt database directly. Beads state must not be pushed or synced from Codex.",
    match = [
        "bd dolt push",
    ],
    not_match = [
        "bd dolt pull",
    ],
)

prefix_rule(
    pattern = ["gh", ["pr", "issue"], ["view", "list", "status"]],
    decision = "allow",
    justification = "Read-only GitHub inspection through gh is allowed.",
    match = [
        "gh pr view 123 --json title,body",
        "gh pr list",
        "gh pr status",
        "gh issue view 42",
        "gh issue list",
        "gh issue status",
    ],
    not_match = [
        "gh pr create",
        "gh issue comment 42 --body hi",
    ],
)
prefix_rule(pattern=["dotnet", "build"], decision="allow")
prefix_rule(pattern=["dotnet", "run"], decision="allow")

prefix_rule(
    pattern = [["sh", "bash", "zsh"]],
    decision = "forbidden",
    justification = "Do not execute shell installers from downloaded scripts.",
    match = [
        "sh",
        "bash",
        "zsh",
        "sh -s",
        "bash -s",
    ],
)

prefix_rule(
    pattern = ["curl"],
    decision = "allow",
    justification = "curl is allowed for direct HTTP requests, but shell installer pipelines must remain blocked by the shell rule.",
    match = [
        "curl https://example.com",
        "curl -fsSL https://example.com/install.sh",
    ],
)

prefix_rule(
    pattern = ["psql"],
    decision = "allow",
    justification = "psql is allowed for database inspection and local development queries.",
    match = [
        "psql --version",
        "psql postgresql://localhost/postgres -c 'select 1'",
    ],
)

prefix_rule(
    pattern = [["docker", "podman"], ["ps", "logs", "inspect", "images", "version", "info", "stats", "top", "events"]],
    decision = "allow",
    justification = "Non-destructive Docker and Podman inspection commands are allowed.",
    match = [
        "docker ps",
        "docker logs api",
        "docker inspect api",
        "docker images",
        "docker version",
        "docker info",
        "docker stats --no-stream",
        "docker top api",
        "podman ps",
        "podman logs api",
    ],
    not_match = [
        "docker run postgres",
        "docker rm api",
        "podman run postgres",
        "podman rm api",
    ],
)

prefix_rule(
    pattern = [["docker", "podman"], ["container", "image", "volume", "network", "context"], "ls"],
    decision = "allow",
    justification = "Non-destructive Docker and Podman list commands are allowed.",
    match = [
        "docker container ls",
        "docker image ls",
        "docker volume ls",
        "docker network ls",
        "docker context ls",
        "podman container ls",
        "podman image ls",
    ],
    not_match = [
        "docker container rm api",
        "docker image rm postgres",
        "docker volume rm data",
        "podman pod rm app",
    ],
)

prefix_rule(
    pattern = ["podman", "pod", "ls"],
    decision = "allow",
    justification = "Non-destructive Podman pod list commands are allowed.",
    match = [
        "podman pod ls",
    ],
    not_match = [
        "podman pod rm app",
    ],
)

prefix_rule(
    pattern = ["docker", "compose", ["ps", "logs", "config", "ls", "images", "top", "port", "version", "events"]],
    decision = "allow",
    justification = "Non-destructive Docker Compose inspection commands are allowed.",
    match = [
        "docker compose ps",
        "docker compose logs",
        "docker compose config",
        "docker compose ls",
        "docker compose images",
        "docker compose top",
        "docker compose port api 8080",
        "docker compose version",
    ],
    not_match = [
        "docker compose up -d",
        "docker compose down -v",
        "docker compose run api",
        "docker compose rm api",
        "docker compose build",
        "docker compose pull",
        "docker compose push",
    ],
)

prefix_rule(
    pattern = [["./gradlew", "gradlew"]],
    decision = "allow",
    justification = "Gradle wrapper commands are allowed for local Android and React Native builds.",
    match = [
        "./gradlew assembleDebug",
        "./gradlew test",
        "gradlew assembleDebug",
    ],
)

prefix_rule(
    pattern = ["npx", "react-native"],
    decision = "allow",
    justification = "React Native CLI commands are allowed for local mobile development workflows.",
    match = [
        "npx react-native start",
        "npx react-native run-android",
        "npx react-native doctor",
    ],
)

prefix_rule(
    pattern = [["npm", "yarn", "pnpm"], "run", ["android", "ios", "start"]],
    decision = "allow",
    justification = "Package-manager React Native entrypoints are allowed for local mobile development workflows.",
    match = [
        "npm run android",
        "npm run ios",
        "npm run start",
        "pnpm run android",
    ],
)

prefix_rule(
    pattern = ["yarn", ["android", "ios", "start", "react-native"]],
    decision = "allow",
    justification = "Yarn React Native entrypoints are allowed for local mobile development workflows.",
    match = [
        "yarn android",
        "yarn ios",
        "yarn start",
        "yarn react-native run-android",
    ],
)

prefix_rule(
    pattern = [["npm", "yarn", "pnpm"], "exec", "react-native"],
    decision = "allow",
    justification = "Package-manager React Native CLI execution is allowed for local mobile development workflows.",
    match = [
        "npm exec react-native run-android",
        "yarn exec react-native run-ios",
        "pnpm exec react-native run-android",
    ],
)
prefix_rule(pattern=["rm", ".next/lock"], decision="allow")
prefix_rule(pattern=["npm", "run", "test:client"], decision="allow")
prefix_rule(pattern=["npm", "install"], decision="allow")
prefix_rule(pattern=["ps", "-ef"], decision="allow")
prefix_rule(pattern=["docker", "ps", "-a"], decision="allow")
prefix_rule(pattern=["env", "CLIENT_BASE_URL=http://127.0.0.1:3100/", "npm", "run", "test:client"], decision="allow")
prefix_rule(pattern=["docker", "stop"], decision="allow")
prefix_rule(pattern=["docker", "build"], decision="allow")
prefix_rule(pattern=["npx", "playwright", "test"], decision="allow")
prefix_rule(pattern=["dotnet", "test"], decision="allow")
prefix_rule(pattern=["npm", "run", "dev"], decision="allow")
prefix_rule(pattern=["/home/carlos/.rotz/bin/rotz", "link"], decision="allow")
prefix_rule(pattern=["npx", "skills"], decision="allow")
prefix_rule(pattern=["/home/carlos/.rotz/bin/rotz", "-r", "install"], decision="allow")
