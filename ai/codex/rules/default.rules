# Codex exec policy. Rules control commands requested outside the sandbox.

prefix_rule(
    pattern = [["tofu", "terraform"]],
    decision = "forbidden",
    justification = "Do not run Terraform/OpenTofu locally. The tailscale-infra repo plans on PR and applies on merge through GitHub Actions.",
    match = [
        "tofu plan",
        "tofu apply",
        "terraform init",
        "terraform plan",
    ],
)

prefix_rule(
    pattern = [["rg", "jq", "ast-grep", "ls", "pwd", "wc", "cat"]],
    decision = "allow",
    justification = "Read-only inspection tools are safe to run outside the sandbox.",
    match = [
        "rg codex",
        "jq . file.json",
        "ast-grep --pattern foo",
        "ls -la",
        "pwd",
        "wc -l README.md",
        "cat AGENTS.md",
    ],
)

prefix_rule(
    pattern = ["git", ["status", "diff", "log", "show"]],
    decision = "allow",
    justification = "Read-only git inspection commands do not mutate the worktree.",
    match = [
        "git status --short",
        "git diff --stat",
        "git log --oneline -5",
        "git show HEAD",
    ],
)

prefix_rule(
    pattern = ["git", "branch", "--show-current"],
    decision = "allow",
    justification = "Reading the current branch does not mutate the worktree.",
    match = [
        "git branch --show-current",
    ],
    not_match = [
        "git branch -D old-branch",
    ],
)

prefix_rule(
    pattern = ["gh", ["pr", "issue"], ["view", "list", "status"]],
    decision = "allow",
    justification = "Read-only GitHub inspection through gh is allowed.",
    match = [
        "gh pr view 123 --json title,body",
        "gh pr list",
        "gh pr status",
        "gh issue view 42",
        "gh issue list",
        "gh issue status",
    ],
    not_match = [
        "gh pr create",
        "gh issue comment 42 --body hi",
    ],
)
prefix_rule(pattern=["dotnet", "build"], decision="allow")
prefix_rule(pattern=["dotnet", "run"], decision="allow")

prefix_rule(
    pattern = [["sh", "bash", "zsh"]],
    decision = "forbidden",
    justification = "Do not execute shell installers from downloaded scripts.",
    match = [
        "sh",
        "bash",
        "zsh",
        "sh -s",
        "bash -s",
    ],
)

prefix_rule(
    pattern = ["curl"],
    decision = "allow",
    justification = "curl is allowed for direct HTTP requests, but shell installer pipelines must remain blocked by the shell rule.",
    match = [
        "curl https://example.com",
        "curl -fsSL https://example.com/install.sh",
    ],
)

prefix_rule(
    pattern = ["psql"],
    decision = "allow",
    justification = "psql is allowed for database inspection and local development queries.",
    match = [
        "psql --version",
        "psql postgresql://localhost/postgres -c 'select 1'",
    ],
)

prefix_rule(
    pattern = [["docker", "podman"], ["ps", "logs", "inspect", "images", "version", "info", "stats", "top", "events"]],
    decision = "allow",
    justification = "Non-destructive Docker and Podman inspection commands are allowed.",
    match = [
        "docker ps",
        "docker logs api",
        "docker inspect api",
        "docker images",
        "docker version",
        "docker info",
        "docker stats --no-stream",
        "docker top api",
        "podman ps",
        "podman logs api",
    ],
    not_match = [
        "docker run postgres",
        "docker rm api",
        "podman run postgres",
        "podman rm api",
    ],
)

prefix_rule(
    pattern = [["docker", "podman"], ["container", "image", "volume", "network", "context"], "ls"],
    decision = "allow",
    justification = "Non-destructive Docker and Podman list commands are allowed.",
    match = [
        "docker container ls",
        "docker image ls",
        "docker volume ls",
        "docker network ls",
        "docker context ls",
        "podman container ls",
        "podman image ls",
    ],
    not_match = [
        "docker container rm api",
        "docker image rm postgres",
        "docker volume rm data",
        "podman pod rm app",
    ],
)

prefix_rule(
    pattern = ["podman", "pod", "ls"],
    decision = "allow",
    justification = "Non-destructive Podman pod list commands are allowed.",
    match = [
        "podman pod ls",
    ],
    not_match = [
        "podman pod rm app",
    ],
)

prefix_rule(
    pattern = ["docker", "compose", ["ps", "logs", "config", "ls", "images", "top", "port", "version", "events"]],
    decision = "allow",
    justification = "Non-destructive Docker Compose inspection commands are allowed.",
    match = [
        "docker compose ps",
        "docker compose logs",
        "docker compose config",
        "docker compose ls",
        "docker compose images",
        "docker compose top",
        "docker compose port api 8080",
        "docker compose version",
    ],
    not_match = [
        "docker compose up -d",
        "docker compose down -v",
        "docker compose run api",
        "docker compose rm api",
        "docker compose build",
        "docker compose pull",
        "docker compose push",
    ],
)

prefix_rule(
    pattern = [["./gradlew", "gradlew"]],
    decision = "allow",
    justification = "Gradle wrapper commands are allowed for local Android and React Native builds.",
    match = [
        "./gradlew assembleDebug",
        "./gradlew test",
        "gradlew assembleDebug",
    ],
)

prefix_rule(
    pattern = ["npx", "react-native"],
    decision = "allow",
    justification = "React Native CLI commands are allowed for local mobile development workflows.",
    match = [
        "npx react-native start",
        "npx react-native run-android",
        "npx react-native doctor",
    ],
)

prefix_rule(
    pattern = [["npm", "yarn", "pnpm"], "run", ["android", "ios", "start"]],
    decision = "allow",
    justification = "Package-manager React Native entrypoints are allowed for local mobile development workflows.",
    match = [
        "npm run android",
        "npm run ios",
        "npm run start",
        "pnpm run android",
    ],
)

prefix_rule(
    pattern = ["yarn", ["android", "ios", "start", "react-native"]],
    decision = "allow",
    justification = "Yarn React Native entrypoints are allowed for local mobile development workflows.",
    match = [
        "yarn android",
        "yarn ios",
        "yarn start",
        "yarn react-native run-android",
    ],
)

prefix_rule(
    pattern = [["npm", "yarn", "pnpm"], "exec", "react-native"],
    decision = "allow",
    justification = "Package-manager React Native CLI execution is allowed for local mobile development workflows.",
    match = [
        "npm exec react-native run-android",
        "yarn exec react-native run-ios",
        "pnpm exec react-native run-android",
    ],
)
prefix_rule(pattern=["rm", ".next/lock"], decision="allow")
prefix_rule(pattern=["npm", "run", "test:client"], decision="allow")
prefix_rule(pattern=["npm", "install"], decision="allow")
prefix_rule(pattern=["ps", "-ef"], decision="allow")
prefix_rule(pattern=["docker", "ps", "-a"], decision="allow")
prefix_rule(pattern=["docker", "stop"], decision="allow")
prefix_rule(pattern=["docker", "build"], decision="allow")
prefix_rule(pattern=["dotnet", "test"], decision="allow")
prefix_rule(pattern=["npm", "run", "dev"], decision="allow")
prefix_rule(pattern=["/home/carlos/.rotz/bin/rotz", "link"], decision="allow")
prefix_rule(pattern=["npx", "skills"], decision="allow")
prefix_rule(pattern=["/home/carlos/.rotz/bin/rotz", "-r", "install"], decision="allow")
prefix_rule(pattern=["op", "item"], decision="allow")
prefix_rule(pattern=["gh", "api"], decision="allow")
prefix_rule(pattern=["uv", "run"], decision="allow")
prefix_rule(pattern=["uv", "lock"], decision="allow")
prefix_rule(pattern=["lsusb"], decision="allow")
prefix_rule(
    pattern = ["git", "commit", "--no-gpg-sign"],
    decision = "forbidden",
    justification = "Agent-created commits must be GPG-signed; do not bypass signing.",
    match = [
        "git commit --no-gpg-sign -m msg",
    ],
)
prefix_rule(
    pattern = ["git", "-c", "commit.gpgsign=false"],
    decision = "forbidden",
    justification = "Agent-created commits must be GPG-signed; do not disable commit.gpgsign.",
    match = [
        "git -c commit.gpgsign=false commit -m msg",
    ],
)
prefix_rule(pattern=["git", "commit", "-S"], decision="allow")
prefix_rule(pattern=["git", "verify-commit"], decision="allow")
prefix_rule(pattern=["cargo", "run"], decision="allow")
prefix_rule(pattern=["journalctl", "--user"], decision="allow")
prefix_rule(pattern=["pypr-client"], decision="allow")
prefix_rule(pattern=["hyprctl"], decision="allow")
prefix_rule(pattern=["git", "add"], decision="allow")
prefix_rule(pattern=["gh", "repo", "view"], decision="allow")
prefix_rule(pattern=["gh", "secret", "list"], decision="allow")
prefix_rule(pattern=["gh", "variable", "list"], decision="allow")
prefix_rule(pattern=["uv", "build"], decision="allow")
prefix_rule(pattern=["systemctl", "show"], decision="allow")
prefix_rule(pattern=["systemctl", "status"], decision="allow")
prefix_rule(pattern=["gcloud", "logging", "read"], decision="allow")
prefix_rule(pattern=["cfg", "leds"], decision="allow")
prefix_rule(pattern=["systemctl", "list-jobs"], decision="allow")
prefix_rule(pattern=["systemd-inhibit"], decision="allow")
prefix_rule(pattern=["systemctl", "--user"], decision="allow")
prefix_rule(pattern=["systemctl", "cat"], decision="allow")
prefix_rule(pattern=["systemd-analyze"], decision="allow")
prefix_rule(pattern=["ss", "-ltnp"], decision="allow")
prefix_rule(pattern=["git", "cherry-pick"], decision="allow")
prefix_rule(pattern=["python", "-m", "unittest"], decision="allow")
prefix_rule(pattern=["git", "spr", "status"], decision="allow")
prefix_rule(pattern=["gh", "pr", "close"], decision="allow")
prefix_rule(pattern=["weidu"], decision="allow")
prefix_rule(pattern=["rm", "uv.lock"], decision="allow")
# E2E tests: export env vars (BASE_URL, auth tokens) in separate shell commands
# before running `npx playwright test`. Services may use ephemeral ports when parallelized.
# Tests must be authorized: always export AUTH/BASE_URL env vars before running.
prefix_rule(pattern=["npx", "playwright", "test"], decision="allow")
prefix_rule(pattern=["set", "-a"], decision="allow")
prefix_rule(pattern=[".", "./.env"], decision="allow")
prefix_rule(pattern=["set", "+a"], decision="allow")
prefix_rule(pattern=["npm", "run", "test:client:firebase-phone"], decision="allow")
prefix_rule(pattern=["tailscale", "status"], decision="allow")
prefix_rule(pattern=["tailscale", "whois"], decision="allow")
prefix_rule(pattern=["argocd"], decision="allow")
prefix_rule(pattern=["gcloud", "secrets", "list", "--project=boletera-qa", "--format=value(name)"], decision="allow")
prefix_rule(pattern=["bundle", "exec", "rails"], decision="allow")
prefix_rule(pattern=["git", "merge-tree"], decision="allow")
prefix_rule(pattern=["git", "fetch"], decision="allow")
prefix_rule(pattern=["agent-browser"], decision="allow")
prefix_rule(pattern=["git", "worktree"], decision="allow")
prefix_rule(pattern=["gcloud", "secrets", "versions", "access", "latest", "--secret=smtp-secret", "--project=boletera-prod"], decision="allow")
prefix_rule(pattern=["npm", "run", "test:admin:headless"], decision="allow")
prefix_rule(pattern=["soffice"], decision="allow")
prefix_rule(pattern=["npm", "run", "test:headless"], decision="allow")
prefix_rule(pattern=["npm", "run", "test:client:headless"], decision="allow")
prefix_rule(pattern=["opencode", "run"], decision="allow")
prefix_rule(pattern=["dotnet", "ef", "migrations"], decision="allow")
prefix_rule(pattern=["pg_ctl"], decision="allow")
prefix_rule(pattern=["createdb"], decision="allow")
prefix_rule(pattern=["cargo", "test"], decision="allow")
prefix_rule(pattern=["cargo", "install"], decision="allow")
prefix_rule(pattern=["/home/carlos/.cargo/bin/brain"], decision="allow")
prefix_rule(pattern=["node", "/tmp/clear_recent_transfer_counterparts.mjs"], decision="allow")
