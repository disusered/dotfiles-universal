{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "macPrimary": "#{{ primary | hex }}",
    "macSecondary": "#{{ secondary | hex }}",
    "macRosewater": "#{{ rosewater | hex }}",
    "macFlamingo": "#{{ flamingo | hex }}",
    "macPink": "#{{ pink | hex }}",
    "macMauve": "#{{ mauve | hex }}",
    "macRed": "#{{ red | hex }}",
    "macMaroon": "#{{ maroon | hex }}",
    "macPeach": "#{{ peach | hex }}",
    "macYellow": "#{{ yellow | hex }}",
    "macGreen": "#{{ green | hex }}",
    "macTeal": "#{{ teal | hex }}",
    "macSky": "#{{ sky | hex }}",
    "macSapphire": "#{{ sapphire | hex }}",
    "macBlue": "#{{ blue | hex }}",
    "macLavender": "#{{ lavender | hex }}",
    "macText": "#{{ text | hex }}",
    "macSubtext1": "#{{ subtext1 | hex }}",
    "macSubtext0": "#{{ subtext0 | hex }}",
    "macOverlay2": "#{{ overlay2 | hex }}",
    "macOverlay1": "#{{ overlay1 | hex }}",
    "macOverlay0": "#{{ overlay0 | hex }}",
    "macSurface2": "#{{ surface2 | hex }}",
    "macSurface1": "#{{ surface1 | hex }}",
    "macSurface0": "#{{ surface0 | hex }}",
    "macBase": "#{{ base | hex }}",
    "macMantle": "#{{ mantle | hex }}",
    "macCrust": "#{{ crust | hex }}"
  },
  "theme": {
    "primary": {
      "dark": "macPrimary",
      "light": "macPrimary"
    },
    "secondary": {
      "dark": "macSecondary",
      "light": "macSecondary"
    },
    "accent": {
      "dark": "macPrimary",
      "light": "macPrimary"
    },
    "error": {
      "dark": "macRed",
      "light": "macRed"
    },
    "warning": {
      "dark": "macYellow",
      "light": "macYellow"
    },
    "success": {
      "dark": "macGreen",
      "light": "macGreen"
    },
    "info": {
      "dark": "macTeal",
      "light": "macTeal"
    },
    "text": {
      "dark": "macText",
      "light": "macText"
    },
    "textMuted": {
      "dark": "macSubtext1",
      "light": "macSubtext1"
    },
    "background": {
      "dark": "macBase",
      "light": "macBase"
    },
    "backgroundPanel": {
      "dark": "macMantle",
      "light": "macMantle"
    },
    "backgroundElement": {
      "dark": "macCrust",
      "light": "macCrust"
    },
    "border": {
      "dark": "macSurface0",
      "light": "macSurface0"
    },
    "borderActive": {
      "dark": "macSurface1",
      "light": "macSurface1"
    },
    "borderSubtle": {
      "dark": "macSurface2",
      "light": "macSurface2"
    },
    "diffAdded": {
      "dark": "macGreen",
      "light": "macGreen"
    },
    "diffRemoved": {
      "dark": "macRed",
      "light": "macRed"
    },
    "diffContext": {
      "dark": "macOverlay2",
      "light": "macOverlay2"
    },
    "diffHunkHeader": {
      "dark": "macPeach",
      "light": "macPeach"
    },
    "diffHighlightAdded": {
      "dark": "macGreen",
      "light": "macGreen"
    },
    "diffHighlightRemoved": {
      "dark": "macRed",
      "light": "macRed"
    },
    "diffAddedBg": {
      "dark": "#{{ green | hex }}80",
      "light": "#{{ green | hex }}80"
    },
    "diffRemovedBg": {
      "dark": "#{{ red | hex }}80",
      "light": "#{{ red | hex }}80"
    },
    "diffContextBg": {
      "dark": "macMantle",
      "light": "macMantle"
    },
    "diffLineNumber": {
      "dark": "macSurface1",
      "light": "macSurface1"
    },
    "diffAddedLineNumberBg": {
      "dark": "#{{ green | hex }}40",
      "light": "#{{ green | hex }}40"
    },
    "diffRemovedLineNumberBg": {
      "dark": "#{{ red | hex }}40",
      "light": "#{{ red | hex }}40"
    },
    "markdownText": {
      "dark": "macText",
      "light": "macText"
    },
    "markdownHeading": {
      "dark": "macPrimary",
      "light": "macPrimary"
    },
    "markdownLink": {
      "dark": "macBlue",
      "light": "macBlue"
    },
    "markdownLinkText": {
      "dark": "macSky",
      "light": "macSky"
    },
    "markdownCode": {
      "dark": "macGreen",
      "light": "macGreen"
    },
    "markdownBlockQuote": {
      "dark": "macYellow",
      "light": "macYellow"
    },
    "markdownEmph": {
      "dark": "macYellow",
      "light": "macYellow"
    },
    "markdownStrong": {
      "dark": "macPeach",
      "light": "macPeach"
    },
    "markdownHorizontalRule": {
      "dark": "macSubtext0",
      "light": "macSubtext0"
    },
    "markdownListItem": {
      "dark": "macBlue",
      "light": "macBlue"
    },
    "markdownListEnumeration": {
      "dark": "macSky",
      "light": "macSky"
    },
    "markdownImage": {
      "dark": "macBlue",
      "light": "macBlue"
    },
    "markdownImageText": {
      "dark": "macSky",
      "light": "macSky"
    },
    "markdownCodeBlock": {
      "dark": "macText",
      "light": "macText"
    },
    "syntaxComment": {
      "dark": "macOverlay2",
      "light": "macOverlay2"
    },
    "syntaxKeyword": {
      "dark": "macPrimary",
      "light": "macPrimary"
    },
    "syntaxFunction": {
      "dark": "macBlue",
      "light": "macBlue"
    },
    "syntaxVariable": {
      "dark": "macRed",
      "light": "macRed"
    },
    "syntaxString": {
      "dark": "macGreen",
      "light": "macGreen"
    },
    "syntaxNumber": {
      "dark": "macPeach",
      "light": "macPeach"
    },
    "syntaxType": {
      "dark": "macYellow",
      "light": "macYellow"
    },
    "syntaxOperator": {
      "dark": "macSky",
      "light": "macSky"
    },
    "syntaxPunctuation": {
      "dark": "macText",
      "light": "macText"
    }
  }
}
