#!/usr/bin/env bash
set -euo pipefail

marketplace_name="${OPENVIKING_CODEX_MARKETPLACE_NAME:-openviking-plugins-local}"
plugin_name="openviking-memory"
plugin_id="${plugin_name}@${marketplace_name}"
codex_config="${CODEX_CONFIG_FILE:-$HOME/.codex/config.toml}"
marketplace_root="${OPENVIKING_CODEX_MARKETPLACE_ROOT:-$HOME/.codex/${marketplace_name}-marketplace}"

script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)"
module_root="$(cd -- "$script_dir/.." && pwd -P)"
plugin_source="${OPENVIKING_CODEX_PLUGIN_SOURCE:-$HOME/.openviking/codex-memory-plugin}"
if [ ! -d "$plugin_source/.codex-plugin" ]; then
  plugin_source="$module_root/codex-memory-plugin"
fi
if [ ! -d "$plugin_source/.codex-plugin" ]; then
  printf 'Codex OpenViking plugin source not found: %s\n' "$plugin_source" >&2
  exit 1
fi
plugin_source="$(cd -- "$plugin_source" && pwd -P)"

plugin_version="$(node -e 'const p=require(process.argv[1]); process.stdout.write(p.version || "0.0.0")' "$plugin_source/.codex-plugin/plugin.json")"
cache_dir="$HOME/.codex/plugins/cache/$marketplace_name/$plugin_name/$plugin_version"

mkdir -p "$marketplace_root/.claude-plugin" "$HOME/.codex" "$(dirname "$cache_dir")"
rm -f "$marketplace_root/$plugin_name"
ln -s "$plugin_source" "$marketplace_root/$plugin_name"

node - "$marketplace_root/.claude-plugin/marketplace.json" "$marketplace_name" "$plugin_name" <<'NODE'
const fs = require("node:fs");
const [file, marketplaceName, pluginName] = process.argv.slice(2);
const data = {
  name: marketplaceName,
  plugins: [
    { name: pluginName, source: `./${pluginName}` },
  ],
};
fs.writeFileSync(file, JSON.stringify(data, null, 2) + "\n");
NODE

codex plugin marketplace add "$marketplace_root" >/dev/null 2>&1 || true

node - "$codex_config" "$plugin_id" <<'NODE'
const fs = require("node:fs");
const file = process.argv[2];
const pluginId = process.argv[3];

let text = "";
try { text = fs.readFileSync(file, "utf8"); } catch {}

function ensureSectionLine(src, section, key, value) {
  const lines = src.split(/\n/);
  const header = `[${section}]`;
  const start = lines.findIndex((line) => line.trim() === header);
  if (start === -1) {
    const prefix = src.trimEnd();
    return `${prefix}${prefix ? "\n\n" : ""}${header}\n${key} = ${value}\n`;
  }

  let end = lines.length;
  for (let i = start + 1; i < lines.length; i += 1) {
    if (/^\s*\[/.test(lines[i])) { end = i; break; }
  }
  for (let i = start + 1; i < end; i += 1) {
    if (new RegExp(`^\\s*${key}\\s*=`).test(lines[i])) {
      lines[i] = `${key} = ${value}`;
      return lines.join("\n").replace(/\n*$/, "\n");
    }
  }
  lines.splice(end, 0, `${key} = ${value}`);
  return lines.join("\n").replace(/\n*$/, "\n");
}

function ensurePluginEnabled(src, id) {
  const header = `[plugins."${id}"]`;
  const lines = src.split(/\n/);
  const start = lines.findIndex((line) => line.trim() === header);
  if (start === -1) {
    const prefix = src.trimEnd();
    return `${prefix}${prefix ? "\n\n" : ""}${header}\nenabled = true\n`;
  }

  let end = lines.length;
  for (let i = start + 1; i < lines.length; i += 1) {
    if (/^\s*\[/.test(lines[i])) { end = i; break; }
  }
  for (let i = start + 1; i < end; i += 1) {
    if (/^\s*enabled\s*=/.test(lines[i])) {
      lines[i] = "enabled = true";
      return lines.join("\n").replace(/\n*$/, "\n");
    }
  }
  lines.splice(end, 0, "enabled = true");
  return lines.join("\n").replace(/\n*$/, "\n");
}

text = ensureSectionLine(text, "features", "plugin_hooks", "true");
text = ensurePluginEnabled(text, pluginId);
fs.mkdirSync(require("node:path").dirname(file), { recursive: true });
fs.writeFileSync(file, text);
NODE

rm -rf "$cache_dir"
cp -R "$plugin_source" "$cache_dir"
OPENVIKING_PLUGIN_CACHE_DIR="$cache_dir" "$script_dir/openviking-codex-plugin-render-cache"

printf 'Installed %s from %s\n' "$plugin_id" "$plugin_source"
printf 'Marketplace: %s\n' "$marketplace_root"
printf 'Plugin cache: %s\n' "$cache_dir"
