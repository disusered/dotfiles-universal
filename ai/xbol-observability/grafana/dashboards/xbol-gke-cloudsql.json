      "id": 1,
      "type": "timeseries",
      "title": "GKE CPU request utilization",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "xbol-victoriametrics"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "topk(10, avg_over_time(stackdriver_k_8_s_container_kubernetes_io_container_cpu_request_utilization{cluster_name=\"boletera-qa\"}[15m]))",
          "range": true,
          "datasource": {
            "type": "prometheus",
            "uid": "xbol-victoriametrics"
          },
          "legendFormat": "{{namespace_name}} {{pod_name}} {{container_name}} {{database_id}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
