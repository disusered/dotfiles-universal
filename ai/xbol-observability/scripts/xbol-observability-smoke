#!/usr/bin/env bash
set -euo pipefail

VM_URL="${XBOL_VM_URL:-http://127.0.0.1:8428}"
GRAFANA_URL="${XBOL_GRAFANA_URL:-http://127.0.0.1:43000}"
ALLOY_URL="${XBOL_ALLOY_URL:-http://127.0.0.1:12345}"

echo "XBOL observability smoke check"
echo "VictoriaMetrics: ${VM_URL}"
echo "Grafana:         ${GRAFANA_URL}"
echo "Alloy:           ${ALLOY_URL}"
echo

check_url() {
  local name="$1" url="$2"
  if curl -fsS --max-time 5 "$url" >/dev/null; then
    echo "ok: ${name} reachable"
  else
    echo "warn: ${name} not reachable at ${url}" >&2
  fi
}

check_url "VictoriaMetrics" "${VM_URL}/health"
check_url "Grafana" "${GRAFANA_URL}/api/health"
check_url "Alloy" "${ALLOY_URL}/-/ready"

echo
echo "GKE metric names in VictoriaMetrics:"
curl -fsS --max-time 10 \
  --get "${VM_URL}/api/v1/label/__name__/values" \
  --data-urlencode 'match[]={__name__=~"stackdriver_k_8_s_container_.*"}' \
  | jq -r '.data[]?' \
  | sort

echo
echo "Cloud SQL metric names in VictoriaMetrics:"
curl -fsS --max-time 10 \
  --get "${VM_URL}/api/v1/label/__name__/values" \
  --data-urlencode 'match[]={__name__=~"stackdriver_cloudsql_database_.*"}' \
  | jq -r '.data[]?' \
  | sort \
  | sed -n '1,80p'

echo
echo "Sample series labels:"
curl -fsS --max-time 10 \
  --get "${VM_URL}/api/v1/series" \
  --data-urlencode 'match[]={__name__=~"stackdriver_.*"}' \
  --data-urlencode 'start='"$(date -u -d '2 hours ago' +%s)" \
  --data-urlencode 'end='"$(date -u +%s)" \
  | jq '.data[:10]'

echo
echo "Useful URLs:"
echo "  Grafana: ${GRAFANA_URL}/d/xbol-gke-cloudsql/xbol-gke-cloud-sql-metrics"
echo "  VictoriaMetrics query UI: ${VM_URL}/vmui/"
echo "  Alloy UI: ${ALLOY_URL}/"
