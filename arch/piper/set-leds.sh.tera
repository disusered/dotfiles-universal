#!/bin/bash
# Set mouse LED colors - Generated by cfg
PROFILE=0
DEVICE="warbling-mara"

# Profile 0 only (active profile)
ratbagctl $DEVICE profile active set $PROFILE
ratbagctl $DEVICE profile $PROFILE led 0 set color {{ primary | darken(amount=30) | hex }}
ratbagctl $DEVICE profile $PROFILE led 1 set color {{ secondary | hex }}
